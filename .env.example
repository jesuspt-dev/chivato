# Supabase Configuration (optional for production)
# Copy to .env.local and fill with your Supabase values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_USE_REMOTE_BACKEND=true

# If you don't configure these variables, the app will work in local mode with localStorage

